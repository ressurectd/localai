# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# --- Tooling caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# --- PRIVATE DATA: never commit ---
# The localai state directory in any of its forms.
localai-data/
.devdata/
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Audit logs and application logs contain file paths from the user's machine.
audit.jsonl
localai.log
logs/

# Backups are copies of the user's own files.
backups/

# Drive and document indexes contain personal data.
index/
*.index

# Extracted document text.
tool-output/
extracted/

# A user's real configuration may name private directories.
config.toml
!examples/**/config.toml

# --- Secrets ---
.env
.env.*
!.env.example
*.pem
*.pfx
*.p12
*.key
credentials.json
secrets.*

# --- Models: far too large, and not ours to distribute ---
*.gguf
*.safetensors
*.bin
*.onnx
models/

# --- Editors and OS ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# --- Generated launcher ---
bin/localai.cmd
bin/localai.ps1

# --- Temporary ---
*.tmp
*.temp
.config-*.toml

# --- Claude Local Instructions ---
CLAUDE.md
# --- release artefacts ---
# dist/ and build/ are already covered by the Python section above.
*.spec.bak
